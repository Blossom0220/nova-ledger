<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context" name="APP_NAME" source="spring.application.name"/>

    <conversionRule conversionWord="sqlclr" converterClass="com.nova.ledger.config.SqlColorConverter"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%thread] %cyan(%logger{36}) - %sqlclr%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <logger name="org.hibernate.SQL" level="DEBUG">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="org.hibernate.orm.jdbc.bind" level="WARN">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="com.nova" level="DEBUG"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
